import { databases } from "@/lib/appwrite"
import { Query } from "appwrite"

const DATABASE_ID = import.meta.env.VITE_APPWRITE_DATABASE_ID
const COLLECTION_ID = import.meta.env.VITE_APPWRITE_CONTACT_COLLECTION_ID

/**
 * Fetch all contact messages, sorted by newest first
 */
export async function fetchContactMessages() {
  try {
    const response = await databases.listDocuments(
      DATABASE_ID,
      COLLECTION_ID,
      [
        Query.orderDesc("$createdAt"),
        Query.limit(100) // Adjust as needed
      ]
    )
    return response.documents
  } catch (error) {
    console.error("Error fetching contact messages:", error)
    throw new Error("Failed to load contact messages")
  }
}

/**
 * Update message status
 */
export async function updateMessageStatus(messageId, status) {
  try {
    const response = await databases.updateDocument(
      DATABASE_ID,
      COLLECTION_ID,
      messageId,
      { status }
    )
    return response
  } catch (error) {
    console.error("Error updating message status:", error)
    throw new Error("Failed to update message status")
  }
}

/**
 * Add admin note to a message
 */
export async function updateAdminNote(messageId, adminNote, handledBy) {
  try {
    const response = await databases.updateDocument(
      DATABASE_ID,
      COLLECTION_ID,
      messageId,
      { 
        admin_note: adminNote,
        handled_by: handledBy,
        handled_at: new Date().toISOString()
      }
    )
    return response
  } catch (error) {
    console.error("Error updating admin note:", error)
    throw new Error("Failed to save admin note")
  }
}

/**
 * Update both status and admin note in one call
 */
export async function updateMessage(messageId, updates) {
  try {
    const payload = { ...updates }
    
    // Add handled metadata if status is being changed to resolved
    if (updates.status === "resolved" && updates.handled_by) {
      payload.handled_at = new Date().toISOString()
    }
    
    const response = await databases.updateDocument(
      DATABASE_ID,
      COLLECTION_ID,
      messageId,
      payload
    )
    return response
  } catch (error) {
    console.error("Error updating message:", error)
    throw new Error("Failed to update message")
  }
}